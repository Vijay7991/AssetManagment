# Copy this file to .env and adjust values.
# Anything secret should be regenerated for production.

# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=assethub
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=assethub
POSTGRES_PORT=5432

# ─── API ─────────────────────────────────────────────────────────
API_PORT=5080
ASPNETCORE_ENVIRONMENT=Development

# IMPORTANT: replace with a 32+ character random string.
# PowerShell:  [Convert]::ToBase64String((1..48 | %{Get-Random -Max 256}))
# Bash:        openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-min-32-chars

JWT_ISSUER=assethub
JWT_AUDIENCE=assethub-clients
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ─── Root admin ─────────────────────────────────────────────────
# Email address of the platform-level "root" admin who can see every
# account and every workspace on this install. The user is auto-promoted
# either at signup or on the next API startup if they already exist.
# Leave empty to disable the cross-tenant admin console entirely.
ROOT_ADMIN_EMAIL=

# Where uploaded files live on the host (mounted into the API container)
UPLOADS_HOST_PATH=./data/uploads

# ─── Web ─────────────────────────────────────────────────────────
WEB_PORT=3000

# Public URL the browser uses to reach the API.
# When accessed via Caddy, leave as /api (relative). When hitting API directly, use http://localhost:5080
NEXT_PUBLIC_API_BASE_URL=/api

# ─── Email (Resend) ───────────────────────────────────────────────
# Get your API key at https://resend.com — add your sending domain there first.
RESEND_API_KEY=re_your_api_key_here
# "From" header shown to recipients. Must match a verified domain in Resend.
RESEND__FROM=AssetHub <no-reply@mail.assethub.uk>

# ─── Resend (production transactional email) ─────────────────────
# Set RESEND_API_KEY to switch the API away from SMTP/MailHog and start
# sending mail via Resend's HTTPS API. Leave empty for dev. RESEND_FROM
# must be a verified sender on your Resend account; until you verify a
# custom domain, "onboarding@resend.dev" works for testing.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ─── Caddy / HTTPS ───────────────────────────────────────────────
# The hostname Caddy will issue an internal cert for.
# 'localhost' works for the host machine. For LAN, you can leave it
# and just hit https://<your-LAN-IP>.
CADDY_HOSTNAME=localhost
