# Env
.env
*.local

# Node
node_modules/
.next/
.turbo/
*.tsbuildinfo
web/package-lock.json

# .NET
bin/
obj/
*.user

# IDE
.vs/
.vscode/
.idea/

# Data (local volumes)
data/
*.log

# Backups produced by scripts/backup.{sh,ps1} — never commit dumps, they
# contain user PII and password hashes.
backups/
*.sql.gz

# Mobile-app binaries served by the web app — too large for git. Drop the
# latest production APK at web/public/downloads/assethub.apk on the host.
web/public/downloads/*.apk
web/public/downloads/*.aab
web/public/downloads/*.ipa
